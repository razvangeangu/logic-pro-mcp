{
  "name": "logic-pro-mcp",
  "display_name": "Logic Pro MCP Server",
  "description": "Bidirectional, stateful control of Logic Pro from AI assistants. 8 tools + 14 resources + 7 templates across 7 native macOS channels (MCU, MIDI Key Commands, CoreMIDI, Scripter, Accessibility, CGEvent, AppleScript). GitHub Actions release assets are universal (`arm64` + `x86_64`); historical local ADHOC prerelease cuts should be audited via RELEASE-METADATA.json.",
  "version": "3.5.0",
  "author": "Isaac (MongLong0214)",
  "license": "MIT",
  "homepage": "https://github.com/MongLong0214/logic-pro-mcp",
  "repository": "https://github.com/MongLong0214/logic-pro-mcp",
  "platforms": ["macos"],
  "supported_architectures": ["arm64", "x86_64"],
  "runtime": "native",
  "min_logic_pro_version": "12.0.1",
  "installation": {
    "macos": {
      "command": "LogicProMCP",
      "args": [],
      "download_url": "https://github.com/MongLong0214/logic-pro-mcp/releases/download/v3.5.0/LogicProMCP",
      "install_path": "/usr/local/bin/LogicProMCP"
    }
  },
  "permissions": [
    "accessibility",
    "automation"
  ],
  "tools": [
    "logic_transport",
    "logic_tracks",
    "logic_mixer",
    "logic_midi",
    "logic_edit",
    "logic_navigate",
    "logic_project",
    "logic_system"
  ],
  "resources": [
    "logic://system/health",
    "logic://transport/state",
    "logic://tracks",
    "logic://mixer",
    "logic://markers",
    "logic://project/info",
    "logic://midi/ports",
    "logic://mcu/state",
    "logic://library/inventory",
    "logic://stock-plugins",
    "logic://stock-plugins/census",
    "logic://stock-plugins/capabilities",
    "logic://workflow-skills",
    "logic://workflow-skills/schema"
  ],
  "resource_templates": [
    "logic://tracks/{index}",
    "logic://tracks/{index}/regions",
    "logic://mixer/{strip}",
    "logic://stock-plugins/{id}",
    "logic://stock-plugins/search?query={query}",
    "logic://workflow-skills/{id}",
    "logic://workflow-skills/search?query={query}"
  ]
}
