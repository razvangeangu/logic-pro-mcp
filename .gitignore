# Per-user inventories regenerated by live scans, never shipped
Resources/*-inventory.json
Resources/*-inventory-*.json
.claude/

# Generated composition attempts and captured media are local artifacts.
# Only the reviewable MIDI-only v4 fixture files are allowed back into the repo.
artifacts/*
!artifacts/acid-track-composition-v4/
!artifacts/acid-track-composition-v4/**

# Logic Pro per-session autosave folders are transient live-session data — the
# v4 whitelist above re-includes everything under the package, so re-ignore any
# Autosave/ dir (no tracked file lives under one; verified with git ls-files).
artifacts/**/Autosave/

# Logic packages embed user-local library/bookmark paths; keep them out of git.
artifacts/**/*.logicx/

# Live-test duplicate created via save_as during live T0/E2E — not shipped
artifacts/acid-track-composition-v4/acid-track-applyback-test.logicx/

# One-off public demo capture/render attempts are local artifacts. The README
# hero demo and its verification helpers are explicitly tracked under docs/media.
docs/media/capture-reddit-*.py
docs/media/render-reddit-*.py
docs/media/reddit-dudddee-*
